Real compra, descuento, total

Inicio

   Escriba "Ingrese el valor de la compra: "
   Lea compra

   Si compra > 1000 Entonces
      descuento <- compra * 0.10
   Sino
      descuento <- 0
   Fin Si

   total <- compra - descuento

   Escriba "Descuento: ", descuento, "  | Total a pagar: ", total

Fin
